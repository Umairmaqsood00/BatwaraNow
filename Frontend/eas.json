{
  "cli": {
    "version": ">= 16.17.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "aab"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "aab",
        "enableBundleCompression": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}
